{
  "ConnectionStrings": {
    "GoalifyDb": "Server=tcp:{{AZURE_SQL_SERVER}}.database.windows.net,1433;Database={{AZURE_SQL_DATABASE}};Authentication=Active Directory Default;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "Database": {
    "RunMigrations": true,
    "SeedData": false,
    "EnableDetailedErrors": false,
    "EnableSensitiveDataLogging": false,
    "CommandTimeoutSeconds": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "https://goalifynow.com",
      "https://www.goalifynow.com"
    ]
  },
  "Stripe": {
    "Enabled": true,
    "ApiKey": "{{STRIPE_API_KEY}}",
    "PublishableKey": "{{STRIPE_PUBLISHABLE_KEY}}",
    "WebhookSecret": "{{STRIPE_WEBHOOK_SECRET}}",
    "SuccessUrl": "https://goalifynow.com/billing?success=true",
    "CancelUrl": "https://goalifynow.com/billing?canceled=true"
  }
}
