## Test Structure

### Standard Test Template
```typescript
import { test, expect } from '../../setup/test-fixtures';
import { MyFeaturePage } from '../../pages/my-feature-page';
import { LoginPage } from '../../pages/login-page';

/**
 * My Feature E2E Tests
 * 
 * Tags: @feature @regression
 */
test.describe('My Feature - Comprehensive Tests @feature @regression', () => {
  let featurePage: MyFeaturePage;
  let loginPage: LoginPage;

  test.beforeEach(async ({ page, demoUsersAvailable }) => {
    test.skip(!demoUsersAvailable, 'Demo users not seeded');
    
    featurePage = new MyFeaturePage(page);
    loginPage = new LoginPage(page);
    
    await loginPage.goto();
    await loginPage.loginAsLandlord();
    await page.waitForURL(url => !url.pathname.includes('/auth/login'), { 
      timeout: 30000 
    });
  });

  test.describe('Page Load @smoke @prod', () => {
    test('should load page successfully', async ({ page }) => {
      await featurePage.goto();
      await featurePage.verifyPageDisplayed();
      await expect(page).toHaveURL(/.*feature/);
    });
  });

  test.describe('Feature Functionality @regression', () => {
    test('should perform action', async () => {
      await featurePage.goto();
      await featurePage.waitForDataLoad();
      // Test implementation
    });
  });

  test.describe('Error Handling @error', () => {
    test('should handle API errors gracefully', async ({ page }) => {
      await page.route('**/api/feature/**', route => route.abort('failed'));
      await featurePage.goto();
      await featurePage.verifyPageDisplayed();
    });
  });

  test.describe('Responsive Design @responsive', () => {
    test('should work on mobile viewport', async ({ page }) => {
      await page.setViewportSize({ width: 375, height: 667 });
      await featurePage.goto();
      await featurePage.verifyPageDisplayed();
    });
  });
});
```

