## Test Fixtures Usage

### Available Fixtures
```typescript
import { test, expect } from '../../setup/test-fixtures';

test.describe('My Tests', () => {
  test('using fixtures', async ({ 
    page,                 // Playwright page
    demoUsersAvailable,   // Boolean: are demo users seeded
    testDataManager,      // Test data creation/cleanup
    authenticatedUser,    // Pre-authenticated user info
    api,                  // API helper
    cleanup               // Cleanup manager
  }) => {
    // Skip if no demo users
    test.skip(!demoUsersAvailable, 'Demo users not seeded');
    
    // Test implementation
  });
});
```

### Authentication Pattern
```typescript
test.beforeEach(async ({ page, demoUsersAvailable }) => {
  test.skip(!demoUsersAvailable, 'Demo users not seeded');
  
  loginPage = new LoginPage(page);
  await loginPage.goto();
  await loginPage.loginAsLandlord();
  
  // Wait for login to complete
  await page.waitForURL(url => !url.pathname.includes('/auth/login'), { 
    timeout: 30000 
  });
});
```

