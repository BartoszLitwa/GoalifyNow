## Configuration & Options Pattern

### Options Class with Const SectionName
```csharp
public class PasswordHashingOptions
{
    public const string SectionName = "PasswordHashing";  // ALWAYS include
    
    public int WorkFactor { get; set; } = 12;
    public bool EnhancedEntropy { get; set; } = true;
}
```

### Registration & Usage
```csharp
// Register
services.Configure<PasswordHashingOptions>(
    configuration.GetSection(PasswordHashingOptions.SectionName)
);

// Inject and use (IOptions for singleton/simple usage)
public class UserPasswordService(IOptions<PasswordHashingOptions> options)
{
    private readonly PasswordHashingOptions _options = options.Value;
    
    public string HashPassword(string password)
    {
        return BCrypt.HashPassword(password, _options.WorkFactor);
    }
}

// IOptionsMonitor for dynamic config that can change at runtime
public class DynamicService(IOptionsMonitor<DynamicOptions> options)
{
    public void DoSomething()
    {
        var current = options.CurrentValue;
    }
}
```

