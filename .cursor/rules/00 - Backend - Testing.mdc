### Service Unit Test Example
```csharp
using Microsoft.EntityFrameworkCore;
using Microsoft.Extensions.Logging.Abstractions;
using Microsoft.Extensions.Options;
using GoalifyNow.Auth.Application.Features.Users.Services;
using GoalifyNow.Auth.Domain.Entities;
using GoalifyNow.Auth.Infrastructure.Persistence;
using GoalifyNow.Auth.UnitTests.Common;
using GoalifyNow.Common.Infrastructure.Context;

namespace GoalifyNow.Auth.UnitTests.Application.Users;

public class UserServiceTests : TestBase
{
    private (AuthDbContext db, ICurrentContextService ctx) CreateContext()
    {
        var ctx = new FakeCurrentContextService();
        var db = AuthTestDb.CreateSqliteContext(ctx);
        return (db, ctx);
    }
    
    [Fact]
    public async Task RegisterAsync_ShouldCreateUser_WhenEmailNotTaken()
    {
        // Arrange
        var country = new Country("United States", "US", "USD", "America/New_York");
        var ctx = new FakeCurrentContextService(tenantId: country.Id);
        var db = AuthTestDb.CreateSqliteContext(ctx);
        
        db.Countries.Add(country);
        await db.SaveChangesAsync();
        
        var svc = new UserService(db, ctx, CreatePasswordService(), NullLogger<UserService>.Instance);
        var dto = new RegisterRequestDto
        {
            Email = "new@example.com",
            Password = "P@ssw0rd",
            FirstName = "John",
            LastName = "Doe",
            CountryId = country.Id
        };
        
        // Act
        var result = await svc.RegisterAsync(dto, CancellationToken.None);
        
        // Assert
        result.IsSuccess.ShouldBeTrue();
        result.Value!.Email.ShouldBe("new@example.com");
        (await db.Users.CountAsync()).ShouldBe(1);
    }
    
    [Fact]
    public async Task RegisterAsync_ShouldFail_WhenEmailAlreadyExists()
    {
        // Arrange
        var (db, ctx) = CreateContext();
        var existingUser = new User { Email = "existing@example.com" };
        db.Users.Add(existingUser);
        await db.SaveChangesAsync();
        
        var svc = new UserService(db, ctx, CreatePasswordService(), NullLogger<UserService>.Instance);
        var dto = new RegisterRequestDto { Email = "existing@example.com" };
        
        // Act
        var result = await svc.RegisterAsync(dto, CancellationToken.None);
        
        // Assert
        result.IsSuccess.ShouldBeFalse();
        result.Error.ShouldContain("already exists");
    }
    
    private static UserPasswordService CreatePasswordService()
    {
        var options = Options.Create(new PasswordHashingOptions());
        return new UserPasswordService(options);
    }
}
```

### Domain Entity Unit Test Example
```csharp
using GoalifyNow.Rentals.Domain.Entities;
using GoalifyNow.Rentals.Domain.Enums;

namespace GoalifyNow.Rentals.UnitTests.Domain.Entities;

public class PropertyTests
{
    [Fact]
    public void AddImage_Should_AddImageToCollection()
    {
        // Arrange
        var property = Property.Create("123 Main St", PropertyType.House, 1500m);
        
        // Act
        property.AddImage("https://example.com/image.jpg", "https://example.com/thumb.jpg");
        
        // Assert
        property.Images.Count.ShouldBe(1);
        property.Images.First().ImageUrl.ShouldBe("https://example.com/image.jpg");
    }
    
    [Fact]
    public void AddImage_Should_RaiseDomainEvent()
    {
        // Arrange
        var property = Property.Create("123 Main St", PropertyType.House, 1500m);
        property.ClearDomainEvents();
        
        // Act
        property.AddImage("https://example.com/image.jpg", "https://example.com/thumb.jpg");
        
        // Assert
        property.DomainEvents.Count.ShouldBe(1);
        property.DomainEvents.First().ShouldBeOfType<PropertyImageAddedEvent>();
    }
}
