## Validator Testing

### FluentValidation Test Helpers
```csharp
using FluentValidation.TestHelper;
using GoalifyNow.Rentals.Application.Features.Properties.Validators;

namespace GoalifyNow.Rentals.UnitTests.Validators;

public class CreatePropertyValidatorTests
{
    private readonly CreatePropertyValidator _validator = new();
    
    [Fact]
    public void Should_HaveError_WhenAddressIsEmpty()
    {
        // Arrange
        var dto = new CreatePropertyDto { Address = "" };
        
        // Act
        var result = _validator.TestValidate(dto);
        
        // Assert
        result.ShouldHaveValidationErrorFor(x => x.Address)
            .WithErrorMessage("Address is required");
    }
    
    [Fact]
    public void Should_HaveError_WhenMonthlyRentIsNegative()
    {
        // Arrange
        var dto = new CreatePropertyDto { MonthlyRent = -100m };
        
        // Act
        var result = _validator.TestValidate(dto);
        
        // Assert
        result.ShouldHaveValidationErrorFor(x => x.MonthlyRent)
            .WithErrorMessage("Monthly rent must be positive");
    }
    
    [Fact]
    public void Should_NotHaveError_WhenDtoIsValid()
    {
        // Arrange
        var dto = new CreatePropertyDto 
        { 
            Address = "123 Main St", 
            MonthlyRent = 1500m,
            Type = PropertyType.House
        };
        
        // Act
        var result = _validator.TestValidate(dto);
        
        // Assert
        result.ShouldNotHaveAnyValidationErrors();
    }
}
```

