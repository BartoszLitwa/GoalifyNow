### Mocking with Moq
```csharp
using Moq;

public class PaymentServiceTests
{
    [Fact]
    public async Task ProcessPayment_Should_CallStripeGateway()
    {
        // Arrange
        var mockStripeGateway = new Mock<IStripeGateway>();
        mockStripeGateway
            .Setup(x => x.CreatePaymentIntentAsync(It.IsAny<decimal>(), It.IsAny<string>()))
            .ReturnsAsync(new PaymentIntent { Id = "pi_123", Status = "succeeded" });
        
        var service = new PaymentService(mockStripeGateway.Object);
        
        // Act
        var result = await service.ProcessPaymentAsync(100m, "usd");
        
        // Assert
        result.IsSuccess.ShouldBeTrue();
        mockStripeGateway.Verify(
            x => x.CreatePaymentIntentAsync(100m, "usd"), 
            Times.Once
        );
    }
}
```

